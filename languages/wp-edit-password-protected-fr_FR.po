#: includes/class-docs.php:30
#: includes/class-docs.php:31
#: includes/class-docs.php:219
#: includes/class-docs.php:225
msgid "Documentation"
msgstr "Documentation"

#: includes/class-docs.php:65
msgid "Getting Started"
msgstr "Premiers pas"

#: includes/class-docs.php:67
msgid "Install and activate the <strong>WPEPP</strong> plugin from the Plugins page."
msgstr "Installez et activez le plugin <strong>WPEPP</strong> depuis la page des plugins."

#: includes/class-docs.php:68
msgid "Navigate to <strong>Password Protected</strong> in the left sidebar of your WordPress dashboard."
msgstr "Accédez à <strong>Protégé par mot de passe</strong> dans la barre latérale gauche de votre tableau de bord WordPress."

#: includes/class-docs.php:69
msgid "You will see a modern tabbed settings panel — this is the main control center for every feature."
msgstr "Vous verrez un panneau de paramètres à onglets moderne — c\'est le centre de contrôle principal pour chaque fonctionnalité."

#: includes/class-docs.php:74
msgid "Site Access Control"
msgstr "Contrôle d\'accès au site"

#: includes/class-docs.php:76
msgid "Go to <strong>Password Protected → Site Access</strong> tab."
msgstr "Accédez à l\'onglet <strong>Protégé par mot de passe → Accès au site</strong>."

#: includes/class-docs.php:77
msgid "<strong>Admin Only Mode</strong> — Restrict the entire site to logged-in administrators only."
msgstr "<strong>Mode administrateur uniquement</strong> — Restreindre l\'intégralité du site aux seuls administrateurs connectés."

#: includes/class-docs.php:78
msgid "<strong>Site Password</strong> — Require a global password for all visitors to access the site."
msgstr "<strong>Mot de passe du site</strong> — Exiger un mot de passe global pour que tous les visiteurs accèdent au site."

#: includes/class-docs.php:79
msgid "Non-authorized visitors will be redirected to the login page or a custom page."
msgstr "Les visiteurs non autorisés seront redirigés vers la page de connexion ou une page personnalisée."

#: includes/class-docs.php:87
msgid "Go to <strong>Password Protected → Content Lock</strong> tab (Pro only)."
msgstr "Accédez à l\'onglet <strong>Protégé par mot de passe → Verrouillage de contenu</strong> (Pro uniquement)."

#: includes/class-docs.php:88
msgid "Enable content lock and configure the locked message visitors will see."
msgstr "Activez le verrouillage de contenu et configurez le message de verrouillage que les visiteurs verront."

#: includes/class-docs.php:89
msgid "Edit any post/page and enable <strong>Content Lock</strong> from the meta box."
msgstr "Modifiez n\'importe quel article/page et activez le <strong>Verrouillage de contenu</strong> depuis le méta-bloc."

#: includes/class-docs.php:90
msgid "Non-logged-in users will see the locked message instead of the post content."
msgstr "Les utilisateurs non connectés verront le message de verrouillage à la place du contenu de l\'article."

#: includes/class-docs.php:95
msgid "Conditional Content Display"
msgstr "Affichage conditionnel du contenu"

#: includes/class-docs.php:97
msgid "Edit any Post or Page and find the <strong>\"Conditional Display\"</strong> meta box in the sidebar."
msgstr ""

#: includes/class-docs.php:98
msgid "Toggle <strong>Enable Conditional Display</strong> on."
msgstr "Activez <strong>Activer l\'affichage conditionnel</strong>."

#: includes/class-docs.php:99
msgid "Choose a basic condition — <em>User is logged in</em> or <em>User is logged out</em>."
msgstr "Choisissez une condition de base — <em>L\'utilisateur est connecté</em> ou <em>L\'utilisateur est déconnecté</em>."

#: includes/class-docs.php:100
msgid "Advanced conditions: User Role, Device Type, Day of Week, Time Range, Date Range, Recurring Schedule, Post Type, Browser Type, URL Parameter, Referrer Source."
msgstr "Conditions avancées : Rôle de l\'utilisateur, Type d\'appareil, Jour de la semaine, Plage horaire, Plage de dates, Planification récurrente, Type d\'article, Type de navigateur, Paramètre d\'URL, Source du référent."

#: includes/class-docs.php:101
msgid "Select an action: <strong>Show</strong> or <strong>Hide</strong> the content when the condition is met."
msgstr "Sélectionnez une action : <strong>Afficher</strong> ou <strong>Masquer</strong> le contenu lorsque la condition est remplie."

#: includes/class-docs.php:102
msgid "Optionally control whether the title and featured image are also hidden."
msgstr "Contrôlez optionnellement si le titre et l\'image mise en avant sont également masqués."

#: includes/class-docs.php:103
msgid "Save the post. The content will now display conditionally on the frontend."
msgstr "Enregistrez l\'article. Le contenu s\'affichera maintenant conditionnellement sur le frontend."

#: includes/class-docs.php:108
msgid "Member-Only Page"
msgstr "Page réservée aux membres"

#: includes/class-docs.php:110
msgid "Create a new <strong>Page</strong> in WordPress."
msgstr "Créez une nouvelle <strong>Page</strong> dans WordPress."

#: includes/class-docs.php:111
msgid "In the Page editor, open <strong>Page Attributes</strong> and select the <em>\"Member Only Template\"</em>."
msgstr ""

#: includes/class-docs.php:112
msgid "Logged-in users will see the page content; logged-out users see the login form."
msgstr "Les utilisateurs connectés verront le contenu de la page ; les utilisateurs déconnectés verront le formulaire de connexion."

#: includes/class-docs.php:113
msgid "Configure the member-only form settings under the <strong>Password Protected</strong> settings panel."
msgstr "Configurez les paramètres du formulaire réservé aux membres dans le panneau de paramètres <strong>Protégé par mot de passe</strong>."

#: includes/class-docs.php:118
msgid "Security Features"
msgstr "Fonctionnalités de sécurité"

#: includes/class-docs.php:120
msgid "Go to <strong>Password Protected → Security</strong> tab."
msgstr "Accédez à l\'onglet <strong>Protégé par mot de passe → Sécurité</strong>."

#: includes/class-docs.php:121
msgid "<strong>Login Limiter</strong> — Set the max number of failed login attempts and lockout duration."
msgstr "<strong>Limiteur de connexion</strong> — Définissez le nombre maximum de tentatives de connexion échouées et la durée de blocage."

#: includes/class-docs.php:122
msgid "<strong>Honeypot</strong> — Enable the invisible honeypot field to catch bots."
msgstr "<strong>Pot de miel</strong> — Activez le champ pot de miel invisible pour attraper les robots."

#: includes/class-docs.php:123
msgid "<strong>Disable XML-RPC</strong> — Block XML-RPC requests to prevent brute-force attacks."
msgstr "<strong>Désactiver XML-RPC</strong> — Bloquez les requêtes XML-RPC pour éviter les attaques par force brute."

#: includes/class-docs.php:124
msgid "<strong>Hide WP Version</strong> — Remove the WordPress version number from your site source."
msgstr "<strong>Masquer la version WP</strong> — Supprimez le numéro de version WordPress du code source de votre site."

#: includes/class-docs.php:125
msgid "<strong>Disable REST User Enumeration</strong> — Prevent user discovery via the REST API."
msgstr "<strong>Désactiver l\'énumération des utilisateurs REST</strong> — Empêchez la découverte d\'utilisateurs via l\'API REST."

#: includes/class-docs.php:126
msgid "<strong>reCAPTCHA</strong> — Add Google reCAPTCHA to the login form."
msgstr "<strong>reCAPTCHA</strong> — Ajoutez Google reCAPTCHA au formulaire de connexion."

#: includes/class-docs.php:127
msgid "<strong>Custom Login URL</strong> — Change the default login URL for added security."
msgstr "<strong>URL de connexion personnalisée</strong> — Modifiez l\'URL de connexion par défaut pour plus de sécurité."

#: includes/class-docs.php:128
msgid "<strong>Login Log</strong> — Track all login attempts with IP and timestamp."
msgstr "<strong>Journal de connexion</strong> — Suivez toutes les tentatives de connexion avec IP et horodatage."

#: includes/class-docs.php:133
#: build/index.js:1
#: src/components/Sidebar.jsx:26
#: src/pages/Dashboard.jsx:184
msgid "Form Style"
msgstr "Style du formulaire"

#: includes/class-docs.php:135
msgid "Go to <strong>Password Protected → Form Style</strong> tab."
msgstr "Accédez à l\'onglet <strong>Protégé par mot de passe → Style du formulaire</strong>."

#: includes/class-docs.php:136
msgid "Choose a form style — Style 1 & Style 2 are available for free."
msgstr "Choisissez un style de formulaire — Style 1 et Style 2 sont disponibles gratuitement."

#: includes/class-docs.php:137
msgid "Style 3 & Style 4 — Additional premium form styles with advanced layouts."
msgstr "Style 3 et Style 4 — Styles de formulaire premium supplémentaires avec des mises en page avancées."

#: includes/class-docs.php:138
msgid "Customize the form label, button text, error message, top/bottom text, and social icons."
msgstr "Personnalisez l\'étiquette du formulaire, le texte du bouton, le message d\'erreur, le texte supérieur/inférieur et les icônes sociales."

#: includes/class-docs.php:139
msgid "<strong>Custom CSS</strong> — Write your own CSS for full control over form styling."
msgstr "<strong>CSS personnalisé</strong> — Écrivez votre propre CSS pour un contrôle total sur le style du formulaire."

#: includes/class-docs.php:140
msgid "Use the <strong>live preview</strong> on the right side to see changes in real time."
msgstr "Utilisez l\'<strong>aperçu en direct</strong> sur le côté droit pour voir les modifications en temps réel."

#: includes/class-docs.php:141
msgid "Click <strong>Save Settings</strong> when you are done."
msgstr "Cliquez sur <strong>Enregistrer les paramètres</strong> lorsque vous avez terminé."

#: includes/class-docs.php:142
msgid "To test, password-protect any post or page from the editor's <em>Visibility</em> setting and view it."
msgstr "Pour tester, protégez par mot de passe n\'importe quel article ou page depuis le paramètre de <em>Visibilité</em> de l\'éditeur et consultez-le."

#: includes/class-docs.php:147
msgid "Login Page Customization"
msgstr "Personnalisation de la page de connexion"

#: includes/class-docs.php:149
msgid "Go to <strong>Password Protected → Login</strong> tab."
msgstr "Accédez à l\'onglet <strong>Protégé par mot de passe → Connexion</strong>."

#: includes/class-docs.php:150
msgid "Upload a custom logo, set background color/image, and style the login form colors."
msgstr "Téléchargez un logo personnalisé, définissez la couleur/image d\'arrière-plan et stylisez les couleurs du formulaire de connexion."

#: includes/class-docs.php:151
msgid "Customize the heading text displayed above the login form."
msgstr "Personnalisez le texte du titre affiché au-dessus du formulaire de connexion."

#: includes/class-docs.php:152
msgid "Toggle the <strong>video background</strong> option for a dynamic login experience."
msgstr "Activez l\'option <strong>arrière-plan vidéo</strong> pour une expérience de connexion dynamique."

#: includes/class-docs.php:153
msgid "<strong>Custom CSS</strong> — Add custom CSS to the login page."
msgstr "<strong>CSS personnalisé</strong> — Ajoutez du CSS personnalisé à la page de connexion."

#: includes/class-docs.php:154
msgid "<strong>Google Fonts</strong> — Choose from hundreds of premium fonts for the login form."
msgstr "<strong>Google Fonts</strong> — Choisissez parmi des centaines de polices premium pour le formulaire de connexion."

#: includes/class-docs.php:155
msgid "Click <strong>Save Settings</strong> and visit <code>wp-login.php</code> to preview."
msgstr "Cliquez sur <strong>Enregistrer les paramètres</strong> et visitez <code>wp-login.php</code> pour l\'aperçu."

#: includes/class-docs.php:160
msgid "Templates Gallery"
msgstr "Galerie de modèles"

#: includes/class-docs.php:162
msgid "Go to <strong>Password Protected → Templates</strong> tab."
msgstr "Accédez à l\'onglet <strong>Protégé par mot de passe → Modèles</strong>."

#: includes/class-docs.php:163
msgid "Browse the template gallery — 3 free templates are included."
msgstr "Parcourez la galerie de modèles — 3 modèles gratuits sont inclus."

#: includes/class-docs.php:164
msgid "Click <strong>Apply</strong> on any template to load its style settings instantly."
msgstr "Cliquez sur <strong>Appliquer</strong> sur n\'importe quel modèle pour charger ses paramètres de style instantanément."

#: includes/class-docs.php:165
msgid "After applying, customize any setting further to match your brand."
msgstr "Après l\'application, personnalisez davantage les paramètres pour correspondre à votre marque."

#: includes/class-docs.php:166
msgid "<strong>Premium Templates</strong> — Unlock all 10+ professionally designed templates."
msgstr "<strong>Modèles premium</strong> — Débloquez tous les 10+ modèles conçus professionnellement."

#: includes/class-docs.php:167
msgid "<strong>Import/Export</strong> — Save and share custom template configurations."
msgstr "<strong>Importation/Exportation</strong> — Enregistrez et partagez des configurations de modèles personnalisés."

#: includes/class-docs.php:172
msgid "FAQ & Troubleshooting"
msgstr "FAQ et dépannage"

#: includes/class-docs.php:175
msgid "The password form does not show my custom styles."
msgstr "Le formulaire de mot de passe n\'affiche pas mes styles personnalisés."

#: includes/class-docs.php:176
msgid "Make sure you clicked <strong>Save Settings</strong>. If you use a caching plugin, clear the cache. Also check that your theme does not override the <code>the_password_form</code> filter."
msgstr "Assurez-vous d\'avoir cliqué sur <strong>Enregistrer les paramètres</strong>. Si vous utilisez un plugin de cache, videz le cache. Vérifiez également que votre thème ne remplace pas le filtre <code>the_password_form</code>."

#: includes/class-docs.php:179
msgid "The login page looks the same as default WordPress."
msgstr "La page de connexion ressemble à la page de connexion WordPress par défaut."

#: includes/class-docs.php:180
msgid "Verify that the Login tab settings are saved. Some security plugins (e.g., Wordfence, iThemes Security) may override login page output."
msgstr "Vérifiez que les paramètres de l\'onglet Connexion sont enregistrés. Certains plugins de sécurité (p. ex., Wordfence, iThemes Security) peuvent remplacer la sortie de la page de connexion."

#: includes/class-docs.php:183
msgid "Conditional display is not working."
msgstr "L\'affichage conditionnel ne fonctionne pas."

#: includes/class-docs.php:184
msgid "Ensure the meta box is enabled on the post/page and that the condition is set correctly. Clear any page cache after saving."
msgstr "Assurez-vous que le méta-bloc est activé sur l\'article/page et que la condition est correctement définie. Videz le cache de page après l\'enregistrement."

#: includes/class-docs.php:187
msgid "I upgraded to Pro but features are still locked."
msgstr "J\'ai mis à niveau vers Pro mais les fonctionnalités sont toujours verrouillées."

#: includes/class-docs.php:188
msgid "Make sure you activated the Pro license key. Go to <strong>Password Protected → License</strong> and verify the status shows \"Active\"."
msgstr ""

#: includes/class-docs.php:191
msgid "Can I use this with WooCommerce product pages?"
msgstr "Puis-je l\'utiliser avec les pages de produits WooCommerce ?"

#: includes/class-docs.php:192
msgid "Yes! Password protection works on any post type that supports it. Conditional Display also works on WooCommerce products."
msgstr "Oui ! La protection par mot de passe fonctionne sur tout type d\'article qui le prend en charge. L\'affichage conditionnel fonctionne également sur les produits WooCommerce."

#: includes/class-docs.php:195
msgid "How do I reset all settings to default?"
msgstr "Comment réinitialiser tous les paramètres par défaut ?"

#: includes/class-docs.php:196
msgid "Deactivate the plugin, delete the <code>wpepp_*</code> options from your database (or use a plugin like WP Reset), then reactivate."
msgstr "Désactivez le plugin, supprimez les options <code>wpepp_*</code> de votre base de données (ou utilisez un plugin comme WP Reset), puis réactivez."

